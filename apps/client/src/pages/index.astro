---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/landing/Hero.astro";
import About from "../components/landing/About.astro";
import Services from "../components/landing/Services.astro";
import WhyChooseUs from "../components/landing/WhyChooseUs.astro";
import Numbers from "../components/landing/Numbers.astro";
import Industries from "../components/landing/Industries.astro";
import Team from "../components/landing/Team.astro";
import Clients from "../components/landing/Clients.astro";
import Testimonials from "../components/landing/Testimonials.astro";
import Contact from "../components/landing/Contact";

const apiUrl = import.meta.env.VITE_API_URL ?? "http://localhost:3001";
---

<Layout>
  <Nav />
  <Hero />
  <About />
  <Services />
  <WhyChooseUs />
  <Numbers />
  <Industries />
  <Team />
  <Clients />
  <Testimonials />
  <Contact apiUrl={apiUrl} client:load />
  <Footer />
</Layout>
