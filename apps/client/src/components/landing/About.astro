<section id="about" class="py-16 md:py-24" data-animate="fade-up">
  <div class="max-w-7xl mx-auto px-4 md:px-8">
    <div class="grid grid-cols-1 md:grid-cols-[2fr_3fr] gap-8 md:gap-12 items-start">
      <h2 class="text-5xl lg:text-6xl xl:text-7xl 2xl:text-8xl font-bold leading-none">About Us</h2>
      <div class="md:max-w-[760px]">
        <p class="text-xl md:text-2xl leading-relaxed text-gray-700">
          Leadsult Consulting is a leading business consulting firm committed to
