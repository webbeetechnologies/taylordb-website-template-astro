<section class="py-16 md:py-24 bg-white" data-animate="fade-up">
  <div class="max-w-7xl mx-auto px-4 md:px-8">
    <div class="grid grid-cols-1 md:grid gap-8 md:gap-16" style="grid-template-columns: auto 60%;">
      <h2 class="text-4xl md:text-6xl font-bold">Our Clients</h2>

      <div>
        <p class="text-gray-600 leading-relaxed mb-8 md:mb-12">
          This is your Client section introductory paragraph. It's a great space
          to talk about the companies you represent or collaborate with on specific
          projects. Add your clients' logos below to create a quick and effective
          visual representation of your relationships
        </p>

        <div class="grid grid-cols-2 md:grid-cols-3 gap-x-8 md:gap-x-12 gap-y-8 md:gap-y-10">
          <div class="flex items-center h-12">
            <img src="/images/logos/logo-1.svg" alt="Client logo 1" class="h-8 w-auto" />
          </div>
          <div class="flex items-center h-12">
            <img src="/images/logos/logo-2.svg" alt="Client logo 2" class="h-8 w-auto" />
          </div>
          <div class="flex items-center h-12">
            <img src="/images/logos/logo-3.svg" alt="Client logo 3" class="h-8 w-auto" />
          </div>
          <div class="flex items-center h-12">
            <img src="/images/logos/logo-4.svg" alt="Client logo 4" class="h-8 w-auto" />
          </div>
          <div class="flex items-center h-12">
            <img src="/images/logos/logo-5.svg" alt="Client logo 5" class="h-8 w-auto" />
          </div>
          <div class="flex items-center h-12">
            <img src="/images/logos/logo-6.svg" alt="Client logo 6" class="h-8 w-auto" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
