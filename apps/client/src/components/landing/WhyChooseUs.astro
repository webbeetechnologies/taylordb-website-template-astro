---
const items = [
  { title: "Strategy",       subtitle: "Tailored Business Strategies" },
  { title: "Analysis",       subtitle: "Data-Driven Insights"         },
  { title: "Development",    subtitle: "Business Growth Plans"        },
  { title: "Implementation", subtitle: "Execution Excellence"         },
];
---

<section class="bg-cream py-16 md:py-24" data-animate="fade-up">
  <div class="max-w-7xl mx-auto px-4 md:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 mb-10 md:mb-16">
      <h2 class="text-4xl md:text-6xl font-bold">Why Choose Us</h2>
      <p class="text-gray-700 leading-relaxed">
        LeadConsult Experts offers expert consulting services to help businesses
        thrive and succeed in today's competitive market. Our team of experienced
        consultants provides tailored solutions to enhance business performance,
        drive growth, and achieve strategic goals
      </p>
    </div>

    <div class="divide-y divide-gray-300 border-t border-gray-300 mt-8">
      {
        items.map((item) => (
          <div class="py-6 md:py-8 flex items-center gap-4 md:gap-6">
            <!-- Navy 4-pointed sparkle star -->
            <svg width="26" height="26" viewBox="0 0 26 26" fill="#0c1c3d" class="shrink-0">
              <path d="M13 0 L14.6 11.4 L26 13 L14.6 14.6 L13 26 L11.4 14.6 L0 13 L11.4 11.4 Z" />
            </svg>
            <span class="text-lg md:text-xl font-bold flex-1">{item.title}</span>
            <span class="text-gray-600 text-sm shrink-0">{item.subtitle}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>
