---
const members = [
  {
    name: "John Doe",
    role: "Business Consultant",
    photo: "/images/team-john.webp",
    bio: "As a seasoned business consultant, John specializes in strategic planning, market analysis, and performance optimization. With a track record of successful project delivery and client satisfaction, he is committed to driving positive outcomes for our clients.",
  },
  {
    name: "Jane Smith",
    role: "Financial Analyst",
    photo: "/images/team-jane.webp",
    bio: "Jane is a skilled financial analyst with expertise in financial modeling, risk assessment, and investment strategies. Her analytical mindset and attention to detail enable her to provide valuable insights and recommendations to support sound financial decisions.",
  },
  {
    name: "Alex Wong",
    role: "Marketing Specialist",
    photo: "/images/team-alex.webp",
    bio: "Alex brings a creative flair and strategic approach to marketing initiatives. With a focus on brand development, digital marketing, and client engagement, Alex helps our clients build strong market presence and connect with their target audiences.",
  },
];
---

<section id="team" class="py-16 md:py-24 bg-white" data-animate="fade-up">
  <div class="max-w-7xl mx-auto px-4 md:px-8">
    <div class="grid grid-cols-1 md:grid-cols-[360px_1fr] gap-8 md:gap-16 mb-6 items-start">
      <h2 class="text-5xl md:text-7xl font-bold leading-none">Meet Our Team</h2>
      <p class="text-gray-600 leading-relaxed text-lg md:max-w-[860px]">
        This is the space to describe the team member. Write a brief description
        of this person's role and responsibilities, or add a short bio with a
        background summary. Highlight their skills and explain what makes them an
        asset to the team.
      </p>
    </div>

    <div class="divide-y divide-gray-300 border-t border-gray-300 mt-10">
      {
        members.map((m) => (
          <div class="py-10 md:py-12 grid grid-cols-1 md:grid-cols-[300px_1fr] gap-8 md:gap-14 items-start">
            <img
              src={m.photo}
              alt={m.name}
              class="w-full max-w-[240px] md:max-w-[300px] aspect-square object-cover object-top rounded-2xl"
            />
            <div class="flex flex-col justify-between gap-6 md:min-h-[300px]">
              <div class="flex items-start gap-4 pt-1">
                <div class="w-3 h-3 rounded-full bg-navy mt-2 shrink-0" />
                <div class="text-2xl md:text-[31px] font-semibold">
                  {m.name}, {m.role}
                </div>
              </div>
              <p class="text-gray-600 text-base md:text-[19px] leading-relaxed md:max-w-[720px]">{m.bio}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
