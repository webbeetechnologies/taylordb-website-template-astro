{
  "name": "@repo/server",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Hono backend server",
  "scripts": {
    "dev": "tsx watch index.ts",
    "build": "pnpm exec esbuild index.ts --bundle --outfile=dist/index.js --format=esm --platform=node --packages=external",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@taylordb/query-builder": "^0.15.0",
    "hono": "^4.7.11",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "esbuild": "^0.27.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}
